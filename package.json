{
  "name": "citation-needed",
  "version": "0.1.0",
  "description": "BibTeX ingestion pipeline for local PDF and Markdown outputs",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "citation-needed": "./bin/citation-needed.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "cli": "node dist/index.js",
    "server": "node dist/index.js server",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}' 'test/**/*.{ts,tsx,json}'",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opendocsg/pdf2md": "^0.2.6",
    "axios": "^1.6.7",
    "better-sqlite3": "^11.10.0",
    "bibtex-parse": "^2.1.0",
    "commander": "^12.0.0",
    "ink": "^3.2.0",
    "react": "^18.2.0"
  },
  "optionalDependencies": {
    "playwright": "^1.41.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
