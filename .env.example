# Copy to .env and edit. None of these are required — defaults apply when unset.

# Base data directory (auth config, default DB and PDF dirs live under this).
CITATION_NEEDED_DIR=~/.citation-needed

# SQLite database file path. Overrides the path under CITATION_NEEDED_DIR.
CITATION_NEEDED_DB=~/.citation-needed/citations.db

# Default PDF storage directory for standalone `download` runs.
# (BibTeX imports default to `papers/pdf/` next to the .bib file regardless.)
CITATION_NEEDED_PDF_DIR=~/.citation-needed/pdfs

# Contact email for the Crossref + Unpaywall User-Agent header.
# Unpaywall *requires* an email; without one, that resolver is skipped.
# `citation-needed auth set-email` takes precedence over this.
# Placeholder domains (@example.com and friends) are treated as unset — Unpaywall
# rejects them with HTTP 422.
CITATION_NEEDED_EMAIL=you@university.edu

# Semantic Scholar API key. Free from https://www.semanticscholar.org/product/api
# Optional, but the single biggest lever on retrieval coverage: without a key the
# Semantic Scholar stage shares an unauthenticated pool that throttles in
# streaks, and a real 56-entry import lost every paper only that source carries.
SEMANTIC_SCHOLAR_API_KEY=

# Logger verbosity. One of: debug | info | warn | error | silent
LOG_LEVEL=info
